---
import '@/styles/global.css';
import { myData } from '@data/myData';
import { Navbar } from '@components/layout/Navbar';
import { Footer } from '@components/layout/Footer';
import { CustomCursor } from '@components/shared/CustomCursor';
import { WhatsAppButton } from '@components/shared/WhatsAppButton';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'AI automation engineer specializing in agentic AI, workflow automation, and full-stack development.',
  ogImage = 'https://res.cloudinary.com/dkcdwyrjl/image/upload/q_auto/f_auto/v1776130837/og-image_fyzcps.jpg',
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="https://res.cloudinary.com/dkcdwyrjl/image/upload/q_auto/f_auto/v1776131024/favicon_bowozg.svg" />
    <link rel="icon" type="image/x-icon" href="https://res.cloudinary.com/dkcdwyrjl/image/upload/q_auto/f_auto/v1776131160/favicon_isjisv.ico" />
    <link rel="shortcut icon" href="https://res.cloudinary.com/dkcdwyrjl/image/upload/q_auto/f_auto/v1776131160/favicon_isjisv.ico" />
    <link rel="apple-touch-icon" href="https://res.cloudinary.com/dkcdwyrjl/image/upload/q_auto/f_auto/v1776130837/og-image_fyzcps.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Roboto:wght@400;500;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Roboto:wght@400;500;700&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <link rel="alternate" type="application/rss+xml" title="Subhan Farrakh Blog" href="/rss.xml" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(myData)} />
    <ClientRouter />
  </head>
  <body class="font-sans antialiased bg-black text-white overflow-x-hidden">
    <CustomCursor client:load />
    <Navbar currentPath={currentPath} client:load />
    <main id="main-content" class="relative gradient text-white min-h-screen">
      <slot />
    </main>
    <WhatsAppButton client:load />
    <Footer client:visible />
  </body>
</html>
