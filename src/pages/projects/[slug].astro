---
import MainLayout from '@layouts/MainLayout.astro';
import { projects } from '@data/projects';

export function getStaticPaths() {
  return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project = projects.find((p) => p.slug === slug);

if (!project) {
  return Astro.redirect('/projects');
}

const schema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: project.title,
  description: project.fullDescription,
  url: `https://subhanfarrakh.com/projects/${project.slug}`,
  image: `https://subhanfarrakh.com${project.image}`,
  author: { "@type": "Person", name: "Subhan Farrakh" },
  datePublished: project.year,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
};
---

<MainLayout title={`${project.title} | Case Study by Subhan Farrakh`} description={project.shortDescription}>
  <section class="min-h-screen bg-black text-white py-20 px-4 md:px-8">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <div class="max-w-4xl mx-auto">
      <a href="/projects" class="inline-flex items-center gap-2 text-gray-400 hover:text-white mb-8 transition-colors">
        ← Back to Projects
      </a>

      <div class="relative h-64 md:h-96 rounded-2xl overflow-hidden mb-8">
        <img src={project.image} alt={project.title} class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent" />
        <div class="absolute bottom-6 left-6">
          <h1 class="text-4xl md:text-5xl font-bold">{project.title}</h1>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
        <div class="bg-white/5 p-4 rounded-xl border border-white/10">
          <p class="text-xs text-gray-400">Year</p>
          <p class="font-semibold">{project.year}</p>
        </div>
        <div class="bg-white/5 p-4 rounded-xl border border-white/10">
          <p class="text-xs text-gray-400">Role</p>
          <p class="font-semibold">{project.role}</p>
        </div>
        <div class="bg-white/5 p-4 rounded-xl border border-white/10">
          <p class="text-xs text-gray-400">Tech Stack</p>
          <p class="font-semibold">{project.technologies.length} tools</p>
        </div>
        {project.client && (
          <div class="bg-white/5 p-4 rounded-xl border border-white/10">
            <p class="text-xs text-gray-400">Client</p>
            <p class="font-semibold">{project.client}</p>
          </div>
        )}
      </div>

      <div class="prose max-w-none mb-10">
        <p class="text-lg text-gray-300 leading-relaxed">{project.fullDescription}</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 mb-10">
        <div class="bg-white/5 p-6 rounded-xl border border-white/10">
          <h2 class="text-xl font-bold mb-4">✨ Key Features</h2>
          <ul class="space-y-2">
            {project.features.map((feature) => (
              <li class="flex items-start gap-2">
                <span class="text-[#1cd8d2] mt-1">•</span>
                <span class="text-gray-300">{feature}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white/5 p-6 rounded-xl border border-white/10">
          <h2 class="text-xl font-bold mb-4">🧩 Challenges & Solutions</h2>
          {project.challenges && (
            <div class="mb-4">
              <p class="text-sm text-gray-400 mb-1">Challenge</p>
              <p class="text-gray-300">{project.challenges}</p>
            </div>
          )}
          {project.solution && (
            <div>
              <p class="text-sm text-gray-400 mb-1">Solution</p>
              <p class="text-gray-300">{project.solution}</p>
            </div>
          )}
        </div>
      </div>

      <div class="bg-gradient-to-r from-[#302b63]/20 via-[#00bf8f]/20 to-[#1cd8d2]/20 p-8 rounded-2xl border border-white/10 text-center">
        {project.outcome && (
          <p class="text-xl font-semibold mb-4">📈 {project.outcome}</p>
        )}
        <div class="flex flex-wrap justify-center gap-4">
          {project.link && (
            <a
              href={project.link}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-3 bg-white text-black rounded-lg font-semibold hover:bg-gray-200 transition-colors"
            >
              Visit Live Project
            </a>
          )}
          <a
            href="/contact"
            class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 text-white rounded-lg font-semibold border border-white/20 hover:bg-white/20 transition-colors"
          >
            Start Your Project
          </a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
