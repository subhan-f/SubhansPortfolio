---
import MainLayout from '@layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
---

<MainLayout title="Blog | Subhan Farrakh" description="Articles about web development, React, Astro, and modern frontend technologies.">
  <section class="min-h-screen bg-black text-white py-20 px-4 md:px-8">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-6xl font-bold mb-4">
          <span class="bg-gradient-to-r from-[#1cd8d2] via-[#00bf8f] to-[#1cd8d2] bg-clip-text text-transparent">Blog</span>
        </h1>
        <p class="text-gray-400 text-lg max-w-2xl mx-auto">
          Thoughts on web development, design, and the tools I use to build modern applications.
        </p>
      </div>

      <!-- Tags -->
      <div class="flex flex-wrap justify-center gap-2 mb-12">
        <a
          href="/blog"
          class="px-4 py-2 rounded-full text-sm font-medium bg-white/10 text-white hover:bg-white/20 transition-colors"
        >
          All
        </a>
        {allTags.map((tag) => (
          <a
            href={`/blog/tag/${tag.toLowerCase().replace(/[\s/]+/g, '-')}`}
            class="px-4 py-2 rounded-full text-sm font-medium bg-white/5 text-gray-300 hover:bg-white/10 transition-colors border border-white/10"
          >
            {tag}
          </a>
        ))}
      </div>

      <!-- Posts Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group block bg-gray-900/50 rounded-xl border border-white/10 overflow-hidden hover:border-[#1cd8d2]/50 transition-all duration-300 hover:-translate-y-1"
          >
            {post.data.image && (
              <div class="aspect-video overflow-hidden">
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
            )}
            <div class="p-6">
              <div class="flex flex-wrap gap-2 mb-3">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="text-xs px-3 py-1 bg-white/10 text-gray-300 rounded-full">
                    {tag}
                  </span>
                ))}
              </div>
              <h2 class="text-xl font-bold mb-2 group-hover:text-[#1cd8d2] transition-colors">
                {post.data.title}
              </h2>
              <p class="text-gray-400 text-sm mb-4 line-clamp-2">
                {post.data.description}
              </p>
              <time class="text-xs text-gray-500" datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              <div class="mt-4 text-sm font-semibold text-[#1cd8d2]">Read Article -></div>
            </div>
          </a>
        ))}
      </div>

      {posts.length === 0 && (
        <div class="text-center py-20 text-gray-500">
          <p class="text-xl">No posts yet. Check back soon!</p>
        </div>
      )}
    </div>
  </section>
</MainLayout>
