---
import MainLayout from '@layouts/MainLayout.astro';
---

<MainLayout title="Page Not Found | Subhan Farrakh">
  <section class="min-h-screen flex items-center justify-center bg-black text-white px-4">
    <div class="text-center max-w-lg">
      <h1 class="text-8xl font-bold bg-gradient-to-r from-[#1cd8d2] to-[#00bf8f] bg-clip-text text-transparent mb-4">
        404
      </h1>
      <p class="text-2xl font-semibold mb-2">Page Not Found</p>
      <p class="text-gray-400 mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="inline-block px-6 py-3 bg-gradient-to-r from-[#1cd8d2] to-[#00bf8f] text-black rounded-lg font-semibold hover:opacity-90 transition-opacity"
      >
        Back to Home
      </a>
    </div>
  </section>
</MainLayout>
