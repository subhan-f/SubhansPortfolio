---
import MainLayout from '@layouts/MainLayout.astro';
import { experiences } from '@data/experiences';
---

<MainLayout title="About Subhan Farrakh | AI Automation Engineer" description="Learn about Subhan Farrakh — an AI automation engineer specializing in agentic AI, workflow automation, and full-stack development. Discover my story, skills, and approach.">
  <section class="min-h-screen bg-black text-white">
    <!-- Hero Banner -->
    <div class="relative overflow-hidden py-24 md:py-32 px-6">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute -top-20 -left-20 w-[400px] h-[400px] rounded-full bg-gradient-to-r from-[#302b63] via-[#00bf8f] to-[#1cd8d2] opacity-15 blur-[140px] animate-pulse" />
        <div class="absolute bottom-0 right-0 w-[350px] h-[350px] rounded-full bg-gradient-to-r from-[#1cd8d2] to-[#302b63] opacity-10 blur-[120px] animate-pulse delay-500" />
      </div>
      <div class="relative z-10 max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-10">
        <div class="shrink-0">
          <img
            src="https://res.cloudinary.com/dkcdwyrjl/image/upload/q_auto/f_auto/v1775601091/Subhan_Farrakh_photo.png"
            alt="Subhan Farrakh"
            loading="eager"
            class="w-44 h-44 md:w-56 md:h-56 rounded-2xl object-cover border border-[#1cd8d2]/25 shadow-2xl"
          />
        </div>
        <div class="text-center md:text-left">
          <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight bg-gradient-to-r from-[#1cd8d2] via-[#00bf8f] to-[#1cd8d2] bg-clip-text text-transparent">
            Subhan Farrakh
          </h1>
          <p class="mt-2 text-xl md:text-2xl text-white/90 font-semibold">AI Automation Engineer</p>
          <p class="mt-1 text-gray-400">COMSATS University Islamabad, Abbottabad Campus</p>
          <div class="mt-6 flex flex-wrap gap-3 justify-center md:justify-start">
            <a href="/contact" class="px-6 py-3 rounded-full font-medium text-black bg-gradient-to-r from-[#1cd8d2] to-[#00bf8f] hover:opacity-90 transition-opacity">
              Let's Work Together
            </a>
            <a href="/Resume.pdf" download class="px-6 py-3 rounded-full font-medium text-white border border-white/20 hover:bg-white/10 transition-colors">
              Download Resume
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- My Story -->
    <div class="max-w-4xl mx-auto px-6 py-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-8">
        <span class="bg-gradient-to-r from-[#1cd8d2] to-[#00bf8f] bg-clip-text text-transparent">My Story</span>
      </h2>
      <div class="space-y-5 text-gray-300 leading-relaxed text-base md:text-lg">
        <p>
          I'm Subhan Farrakh — an AI Automation Engineer who helps businesses eliminate hundreds of hours of manual work through intelligent automation systems. Based in Pakistan and working remotely with clients across the USA, Europe, and Asia, I bridge the gap between complex AI technology and practical business outcomes.
        </p>
        <p>
          My journey started with a fascination for making things work smarter, not harder. While studying at COMSATS University Islamabad (Abbottabad Campus), I dove deep into software engineering and quickly realized that the real power of code lies in its ability to replace tedious, repetitive tasks with systems that run themselves.
        </p>
        <p>
          That realization became my career. Over the past 1.5+ years, I've designed and deployed automation solutions for businesses of all sizes — from real-estate firms processing leads at scale to property maintenance companies handling hundreds of work orders daily. Every project I take on has the same goal: measurable impact.
        </p>
        <p>
          What sets me apart isn't just technical skill — it's the way I think about problems. I don't just write code; I study your workflow, identify the bottlenecks, and architect a solution that eliminates them permanently. Whether that's building a voice AI agent that cuts support calls by 75%, or designing an end-to-end pipeline that reduces data entry by 90%, I'm obsessed with the numbers that matter to your business.
        </p>
      </div>
    </div>

    <!-- What I Do -->
    <div class="bg-white/[0.02] border-y border-white/5">
      <div class="max-w-5xl mx-auto px-6 py-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-10 text-center">
          <span class="bg-gradient-to-r from-[#1cd8d2] to-[#00bf8f] bg-clip-text text-transparent">What I Do</span>
        </h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white/5 rounded-2xl p-6 border border-white/10 hover:border-[#1cd8d2]/30 transition-colors">
            <div class="text-3xl mb-3">🤖</div>
            <h3 class="text-xl font-bold mb-2">AI Automation & Agentic AI</h3>
            <p class="text-gray-400 text-sm leading-relaxed">
              I design end-to-end automation pipelines using n8n, Make.com, and Zapier that connect your CRMs, spreadsheets, and communication tools. I also build agentic AI systems — autonomous AI agents that can reason, take actions, and complete multi-step workflows on their own.
            </p>
          </div>
          <div class="bg-white/5 rounded-2xl p-6 border border-white/10 hover:border-[#1cd8d2]/30 transition-colors">
            <div class="text-3xl mb-3">🗣️</div>
            <h3 class="text-xl font-bold mb-2">Voice AI & Conversational Agents</h3>
            <p class="text-gray-400 text-sm leading-relaxed">
              Using tools like Vapi.ai and Twilio, I build voice-based AI agents that handle customer inquiries, update systems in real-time, and eliminate the need for manual call-backs — all while sounding natural and professional.
            </p>
          </div>
          <div class="bg-white/5 rounded-2xl p-6 border border-white/10 hover:border-[#1cd8d2]/30 transition-colors">
            <div class="text-3xl mb-3">🌐</div>
            <h3 class="text-xl font-bold mb-2">Full-Stack Web Development</h3>
            <p class="text-gray-400 text-sm leading-relaxed">
              I build modern, performant web applications using the MERN stack (MongoDB, Express, React, Node.js), Astro, and Tailwind CSS. Every site I build is designed for speed, SEO, and a seamless user experience.
            </p>
          </div>
          <div class="bg-white/5 rounded-2xl p-6 border border-white/10 hover:border-[#1cd8d2]/30 transition-colors">
            <div class="text-3xl mb-3">📊</div>
            <h3 class="text-xl font-bold mb-2">CRM & API Integrations</h3>
            <p class="text-gray-400 text-sm leading-relaxed">
              From HubSpot and Monday.com to Airtable and custom REST APIs, I connect your business tools into a unified, automated ecosystem. Data flows where it needs to — automatically, accurately, and in real-time.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Technical Toolkit -->
    <div class="max-w-5xl mx-auto px-6 py-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-10 text-center">
        <span class="bg-gradient-to-r from-[#1cd8d2] to-[#00bf8f] bg-clip-text text-transparent">Technical Toolkit</span>
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        {[
          { category: "Automation", tools: ["n8n", "Make.com", "Zapier", "Webhooks"] },
          { category: "AI / ML", tools: ["Vapi.ai", "OpenAI API", "LangChain", "Agentic AI"] },
          { category: "Frontend", tools: ["React", "Astro", "Tailwind CSS", "Framer Motion"] },
          { category: "Backend", tools: ["Node.js", "Express", "MongoDB", "PostgreSQL"] },
          { category: "CRM & Tools", tools: ["HubSpot", "Monday.com", "Airtable", "Podio"] },
          { category: "Cloud", tools: ["GCP", "Docker", "Vercel", "REST APIs"] },
          { category: "Languages", tools: ["JavaScript", "TypeScript", "Python", "SQL"] },
          { category: "Other", tools: ["Git", "Twilio", "Socket.io", "Redis"] },
        ].map((group) => (
          <div class="bg-white/5 rounded-xl p-4 border border-white/10">
            <h3 class="text-sm font-bold text-[#1cd8d2] mb-2 uppercase tracking-wider">{group.category}</h3>
            <ul class="space-y-1">
              {group.tools.map((tool) => (
                <li class="text-gray-300 text-sm">{tool}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <!-- Work Experience -->
    <div class="bg-white/[0.02] border-y border-white/5">
      <div class="max-w-4xl mx-auto px-6 py-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-10 text-center">
          <span class="bg-gradient-to-r from-[#1cd8d2] to-[#00bf8f] bg-clip-text text-transparent">Work Experience</span>
        </h2>
        <div class="space-y-8">
          {experiences.map((exp) => (
            <a href={`/experience/${exp.slug}`} class="block group bg-white/5 rounded-2xl p-6 border border-white/10 hover:border-[#1cd8d2]/40 transition-all duration-300">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-3">
                <div>
                  <h3 class="text-xl font-bold group-hover:text-[#1cd8d2] transition-colors">{exp.role}</h3>
                  <p class="text-gray-400">{exp.company} · {exp.location}</p>
                </div>
                <span class="text-sm text-gray-500 shrink-0">{exp.duration}</span>
              </div>
              <p class="text-gray-300 text-sm mb-3">{exp.shortDescription}</p>
              <div class="flex flex-wrap gap-2">
                {exp.technologies.slice(0, 5).map((tech) => (
                  <span class="text-xs px-2 py-1 bg-[#1cd8d2]/10 text-[#1cd8d2] rounded-full">{tech}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- My Approach -->
    <div class="max-w-4xl mx-auto px-6 py-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-8">
        <span class="bg-gradient-to-r from-[#1cd8d2] to-[#00bf8f] bg-clip-text text-transparent">My Approach</span>
      </h2>
      <div class="space-y-6">
        {[
          { step: "01", title: "Understand the Problem", desc: "I start every project by deeply understanding your business workflow, pain points, and goals. No template solutions — every automation is built around your specific needs." },
          { step: "02", title: "Architect the Solution", desc: "I map out the entire data flow, identify integration points, and design a system architecture that's robust, scalable, and easy to maintain." },
          { step: "03", title: "Build & Iterate", desc: "Development is fast and transparent. I deliver working prototypes early, collect feedback, and refine until the solution is exactly right." },
          { step: "04", title: "Deploy & Support", desc: "I don't just hand off code and disappear. I deploy with monitoring, error handling, and documentation — and I'm available for ongoing support." },
        ].map((item) => (
          <div class="flex gap-5 items-start">
            <div class="shrink-0 w-12 h-12 rounded-xl bg-gradient-to-r from-[#1cd8d2] to-[#00bf8f] flex items-center justify-center text-black font-bold text-lg">
              {item.step}
            </div>
            <div>
              <h3 class="text-lg font-bold mb-1">{item.title}</h3>
              <p class="text-gray-400 text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="max-w-4xl mx-auto px-6 pb-20">
      <div class="bg-gradient-to-r from-[#1cd8d2]/10 to-[#00bf8f]/10 rounded-2xl p-8 md:p-12 border border-[#1cd8d2]/20 text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to Automate Your Business?</h2>
        <p class="text-gray-400 mb-8 max-w-2xl mx-auto">
          Whether you need workflow automation, a voice AI agent, or a full-stack web application — I'd love to hear about your project and show you what's possible.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="/contact" class="px-8 py-3 rounded-full font-semibold text-black bg-gradient-to-r from-[#1cd8d2] to-[#00bf8f] hover:opacity-90 transition-opacity">
            Start a Conversation
          </a>
          <a href="/projects" class="px-8 py-3 rounded-full font-semibold text-white border border-white/20 hover:bg-white/10 transition-colors">
            See My Work
          </a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
