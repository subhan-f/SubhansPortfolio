---
import MainLayout from '@layouts/MainLayout.astro';
import { experiences } from '@data/experiences';
---

<MainLayout title="Professional Experience | AI Automation & Development" description="Explore Subhan Farrakh's professional journey in AI automation, full-stack development, and workflow optimization across international clients.">
  <section class="min-h-screen bg-black text-white py-20 px-4 md:px-8">
    <div class="max-w-5xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-center mb-4">
        <span class="bg-gradient-to-r from-[#1cd8d2] via-[#00bf8f] to-[#1cd8d2] bg-clip-text text-transparent">
          Professional Journey
        </span>
      </h1>
      <p class="text-gray-400 text-center max-w-2xl mx-auto mb-12">
        Where I've delivered impact through automation and development.
      </p>

      <div class="space-y-6">
        {experiences.map((exp) => (
          <a href={`/experience/${exp.slug}`} class="block group">
            <div class="relative overflow-hidden rounded-xl bg-gray-900/50 border border-white/10 p-6 md:p-8 hover:border-[#1cd8d2]/50 hover:-translate-y-1 transition-all duration-300">
              <div class="absolute inset-0 bg-gradient-to-r from-[#1cd8d2]/0 via-[#1cd8d2]/0 to-[#1cd8d2]/0 group-hover:from-[#1cd8d2]/5 group-hover:via-transparent group-hover:to-transparent transition-all duration-500" />
              <div class="relative z-10">
                <div class="flex flex-wrap items-start justify-between gap-4 mb-3">
                  <div>
                    <h2 class="text-2xl md:text-3xl font-bold group-hover:text-[#1cd8d2] transition-colors">
                      {exp.role}
                    </h2>
                    <p class="text-lg text-gray-300">{exp.company}</p>
                  </div>
                </div>

                <div class="flex flex-wrap gap-4 text-sm text-gray-400 mb-4">
                  <span>{exp.duration}</span>
                  {exp.location && <span>{exp.location}</span>}
                </div>

                <p class="text-gray-300 mb-4">{exp.shortDescription}</p>

                <div class="flex flex-wrap gap-2">
                  {exp.technologies.slice(0, 4).map((tech) => (
                    <span class="text-xs px-3 py-1 bg-white/10 rounded-full text-gray-300">
                      {tech}
                    </span>
                  ))}
                  {exp.technologies.length > 4 && (
                    <span class="text-xs px-3 py-1 bg-white/10 rounded-full text-gray-300">
                      +{exp.technologies.length - 4}
                    </span>
                  )}
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
