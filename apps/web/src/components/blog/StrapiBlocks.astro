---
import { marked } from 'marked';
import { getStrapiMedia } from '@lib/strapi';
import type { StrapiBlock } from '@lib/strapi';

interface Props {
  blocks: StrapiBlock[];
}

const { blocks } = Astro.props;
---

{blocks.map((block) => {
  if (block.__component === 'shared.rich-text') {
    return (
      <div
        class="prose prose-invert max-w-none"
        set:html={marked.parse(block.body ?? '')}
      />
    );
  }

  if (block.__component === 'shared.media' && block.file) {
    return (
      <figure class="my-8">
        <img
          src={getStrapiMedia(block.file.url)}
          alt={block.file.alternativeText ?? ''}
          class="w-full rounded-xl"
          loading="lazy"
        />
      </figure>
    );
  }

  if (block.__component === 'shared.quote') {
    return (
      <blockquote class="border-l-4 border-[#1cd8d2] pl-6 my-8 italic text-gray-300">
        {block.title && <p class="font-semibold text-white not-italic mb-1">{block.title}</p>}
        <p>{block.body}</p>
      </blockquote>
    );
  }

  if (block.__component === 'shared.slider' && block.files?.length) {
    return (
      <div class="grid grid-cols-2 gap-4 my-8">
        {block.files.map((f) => (
          <img
            src={getStrapiMedia(f.url)}
            alt={f.alternativeText ?? ''}
            class="w-full rounded-lg object-cover"
            loading="lazy"
          />
        ))}
      </div>
    );
  }

  return null;
})}
