---
import MainLayout from './MainLayout.astro';

interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  updatedDate?: Date;
  author?: string;
  ogImage?: string;
  tags?: string[];
  image?: string;
  readingTime?: number;
}

const { title, description, pubDate, author = 'Subhan Farrakh', ogImage, tags = [], readingTime } = Astro.props;
---

<MainLayout title={`${title} | Subhan Farrakh Blog`} description={description} ogImage={ogImage}>
  <slot name="head" />
  <article class="min-h-screen bg-black text-white py-20 px-4 md:px-8">
    <div class="max-w-3xl mx-auto">
      <a
        href="/blog"
        aria-label="Back to all blog posts"
        class="inline-flex items-center gap-2 text-gray-400 hover:text-white mb-8 transition-colors"
      >
        ← Back to Blog
      </a>

      <header class="mb-10">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">{title}</h1>
        <div class="flex flex-wrap items-center gap-4 text-sm text-gray-400">
          {pubDate && (
            <time datetime={pubDate instanceof Date ? pubDate.toISOString() : pubDate}>
              {(pubDate instanceof Date ? pubDate : new Date(pubDate)).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
          )}
          <span>By {author}</span>
          {readingTime && <span>{readingTime} min read</span>}
        </div>
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {tags.map((tag: string) => (
              <a
                href={`/blog/tag/${tag.toLowerCase().replace(/[\s/]+/g, '-')}`}
                class="text-xs px-3 py-1 bg-white/10 rounded-full text-gray-300 hover:bg-[#1cd8d2] hover:text-black transition-colors"
              >
                {tag}
              </a>
            ))}
          </div>
        )}
      </header>

      <div class="prose max-w-none">
        <slot />
      </div>

      <slot name="post-nav" />

      <footer class="mt-16 pt-8 border-t border-white/10">
        <div class="text-center">
          <p class="text-gray-400 mb-4">Enjoyed this article?</p>
          <a
            href="/contact"
            aria-label="Contact Subhan Farrakh to work together"
            class="inline-block px-6 py-3 bg-[#1cd8d2] text-black rounded-lg font-semibold hover:bg-[#00bf8f] transition-colors"
          >
            Let's Work Together
          </a>
        </div>
      </footer>
    </div>
  </article>
</MainLayout>
