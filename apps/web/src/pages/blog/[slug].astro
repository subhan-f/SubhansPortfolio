---
import BlogLayout from '@layouts/BlogLayout.astro';
import StrapiBlocks from '@components/blog/StrapiBlocks.astro';
import { fetchStrapi, getStrapiMedia } from '@lib/strapi';
import type { StrapiList, StrapiArticle } from '@lib/strapi';

export async function getStaticPaths() {
  const { data: posts } = await fetchStrapi<StrapiList<StrapiArticle>>(
    '/articles',
    { 'sort': 'publishedAt:desc' }
  );

  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: { post, prevPost: posts[index + 1] ?? null, nextPost: posts[index - 1] ?? null },
  }));
}

const { post, prevPost, nextPost } = Astro.props as {
  post: StrapiArticle;
  prevPost: StrapiArticle | null;
  nextPost: StrapiArticle | null;
};

// Fetch full post with all populated relations
const { data: posts } = await fetchStrapi<StrapiList<StrapiArticle>>(
  '/articles',
  {
    'filters[slug][$eq]': post.slug,
    'populate[cover]': 'true',
    'populate[author]': 'true',
    'populate[category]': 'true',
    'populate[blocks][populate]': '*',
  }
);
const fullPost = posts[0] ?? post;

const tags = fullPost.tags ?? (fullPost.category ? [fullPost.category.name] : []);
const author = fullPost.author?.name ?? 'Subhan Farrakh';
const pubDate = new Date(fullPost.publishedAt);
const updatedDate = fullPost.updatedAt ? new Date(fullPost.updatedAt) : undefined;

const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: fullPost.title,
  description: fullPost.description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  author: { '@type': 'Person', name: author, sameAs: 'https://subhanfarrakh.com/#person' },
  ...(fullPost.cover?.url && { image: getStrapiMedia(fullPost.cover.url) }),
  keywords: tags.join(', '),
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://subhanfarrakh.com/blog/${fullPost.slug}/`,
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://subhanfarrakh.com/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://subhanfarrakh.com/blog/' },
    { '@type': 'ListItem', position: 3, name: fullPost.title, item: `https://subhanfarrakh.com/blog/${fullPost.slug}/` },
  ],
};
---

<BlogLayout
  title={fullPost.title}
  description={fullPost.description}
  pubDate={pubDate}
  updatedDate={updatedDate}
  author={author}
  tags={tags}
  image={getStrapiMedia(fullPost.cover?.url)}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  {fullPost.blocks?.length ? (
    <StrapiBlocks blocks={fullPost.blocks} />
  ) : (
    <p class="text-gray-400 italic">This article has no content blocks yet.</p>
  )}

  <nav slot="post-nav" class="mt-12 pt-8 border-t border-white/10 grid grid-cols-2 gap-4">
    {prevPost ? (
      <a
        href={`/blog/${prevPost.slug}`}
        class="group flex flex-col p-4 bg-white/5 rounded-xl border border-white/10 hover:border-[#1cd8d2]/50 transition-colors"
      >
        <span class="text-xs text-gray-500 mb-1">← Previous</span>
        <span class="text-sm font-semibold group-hover:text-[#1cd8d2] transition-colors">{prevPost.title}</span>
      </a>
    ) : <div />}
    {nextPost ? (
      <a
        href={`/blog/${nextPost.slug}`}
        class="group flex flex-col items-end text-right p-4 bg-white/5 rounded-xl border border-white/10 hover:border-[#1cd8d2]/50 transition-colors"
      >
        <span class="text-xs text-gray-500 mb-1">Next →</span>
        <span class="text-sm font-semibold group-hover:text-[#1cd8d2] transition-colors">{nextPost.title}</span>
      </a>
    ) : <div />}
  </nav>
</BlogLayout>
