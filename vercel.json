{
  "builds": [
    {
      "src": "build/server/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/build/client/assets/$1"
    },
    {
      "src": "/(.*)\\.(js|css|png|jpg|jpeg|svg|webp|avif|ico|json|txt|xml)",
      "dest": "/build/client/$1.$2"
    },
    {
      "src": "/(.*)",
      "dest": "/build/server/index.js"
    }
  ],
  "outputDirectory": "build/client"
}